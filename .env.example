# Public API base URL (browser-safe). Use https in production.
# Example (issue #31, dashboard backend): https://mota-app.duckdns.org
NEXT_PUBLIC_API_BASE=https://api.example.com

# Kakao Maps JavaScript key (browser-safe / NEXT_PUBLIC_).
# Restrict allowed domains in Kakao Developers → App → Platform.
# Leave empty locally to use the map fallback UI.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
